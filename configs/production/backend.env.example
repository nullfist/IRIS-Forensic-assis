IRIS_NEO4J_USER=neo4j
IRIS_NEO4J_PASSWORD=${IRIS_NEO4J_PASSWORD}
IRIS_REDIS_URL=redis://redis:6379/0
IRIS_MAX_UPLOAD_SIZE=104857600
IRIS_WORKER_QUEUE_NAME=iris-ingest
