APP_NAME=IRIS DFIR API
ENVIRONMENT=production
API_PREFIX=/api/v1
POSTGRES_DSN=postgresql://iris:${IRIS_DB_PASSWORD}@postgres:5432/iris
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=${IRIS_NEO4J_PASSWORD}
REDIS_URL=redis://redis:6379/0
MAX_UPLOAD_SIZE=104857600
WORKER_QUEUE_NAME=iris-ingest
DEFAULT_INVESTIGATION_WINDOW_HOURS=168
IRIS_APP_NAME=IRIS DFIR API
IRIS_ENVIRONMENT=production
IRIS_API_PREFIX=/api/v1
